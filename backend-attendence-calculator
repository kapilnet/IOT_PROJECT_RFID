import json
import boto3
from boto3.dynamodb.conditions import Key

dynamodb = boto3.resource('dynamodb')
table = dynamodb.Table('StudentAttendance')

# Total classes held in the semester so far
TOTAL_CLASSES = 50 

def lambda_handler(event, context):
    # Get UID from the website request
    student_id = event.get('queryStringParameters', {}).get('uid')
    
    if not student_id:
        return {"statusCode": 400, "body": json.dumps({"error": "UID is required"})}

    # Query DynamoDB to count how many times this student has scanned
    response = table.query(
        KeyConditionExpression=Key('student_id').eq(student_id)
    )
    
    scans = response.get('Items', [])
    total_present = len(scans)
    
    # Calculate Percentage
    percentage = (total_present / TOTAL_CLASSES) * 100
    status = "Safe" if percentage >= 70 else "Shortage"
    
    result = {
        "student_id": student_id,
        "present_days": total_present,
        "total_days": TOTAL_CLASSES,
        "percentage": round(percentage, 2),
        "status": status,
        "classes_needed": max(0, int(0.7 * TOTAL_CLASSES) - total_present)
    }

    return {
        "statusCode": 200,
        "headers": {
            "Access-Control-Allow-Origin": "*", # Required for website access
            "Content-Type": "application/json"
        },
        "body": json.dumps(result)
    }
